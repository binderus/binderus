# Patch 5/10: OS Auto-Detect on /download Page
# File: /Users/dylan/work/bindeck-website/app/index.html (download route)
#
# Context: The /download page shows 3 OS tiles (macOS / Windows / Linux)
# with no indication of which one matches the visitor's device. The user
# must know their OS and scroll to the right section — adding friction
# at the exact moment of conversion.
#
# Impact: MEDIUM — reduces choice friction on the download page. Helps
# users on their first visit feel the page is built for them, especially
# useful for macOS where Apple Silicon vs Intel architecture is confusing.
#
# Apply: Open app/index.html (or the download route template), find the
# closing </body> tag, and insert the <script> block just before it.
# Also add the CSS rules to the app's stylesheet (or <head> <style>).
#
# --- begin insertion: add before </body> ---

  <!-- OS auto-detect: highlights the user's platform tile on /download -->
  <script>
    (function() {
      var os = navigator.platform.toLowerCase();
      var selector = null;
      if (os.includes('mac'))       selector = '#macos';
      else if (os.includes('win'))  selector = '#windows';
      else if (os.includes('linux')) selector = '#linux';

      if (selector) {
        var tile = document.querySelector(selector);
        if (tile) {
          tile.classList.add('recommended');
          tile.scrollIntoView({ behavior: 'smooth', block: 'center' });

          // Add a subtle badge: "Recommended for your device"
          var badge = document.createElement('span');
          badge.textContent = 'Recommended for your device';
          badge.className = 'os-recommended-badge';
          tile.prepend(badge);

          // Auto-select architecture for macOS (Apple Silicon vs Intel)
          if (os.includes('mac')) {
            var isArm = navigator.userAgent.includes('Apple') ||
                        navigator.userAgent.includes('arm64');
            var dmgLink = isArm
              ? tile.querySelector('a[href$="arm64.dmg"]')
              : tile.querySelector('a[href$="x64.dmg"]');
            if (dmgLink) dmgLink.classList.add('default-download');
          }
        }
      }
    })();
  </script>

