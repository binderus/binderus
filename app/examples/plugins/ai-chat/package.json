{
  "name": "ai-chat-plugin",
  "version": "0.2.8",
  "private": true,
  "description": "Binderus user plugin: chat with any OpenAI-compatible LLM using the current editor, selection, files, or a folder as context.",
  "type": "module",
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "package": "node esbuild.mjs && node ./scripts/pack-zip.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
